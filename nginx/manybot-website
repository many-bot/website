server {
    server_name manybot.stxerr.dev;

    error_page 404 /404.html;
    error_page 403 /403.html;
    error_page 500 /500.html;
    error_page 503 /503.html;

    location / {
      proxy_pass http://127.0.0.1:3003;

      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/manybot.stxerr.dev/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/manybot.stxerr.dev/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    if ($host = manybot.stxerr.dev) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    server_name manybot.stxerr.dev;
    listen 80;
    return 404; # managed by Certbot
}

